# ---------------------------------------------------------------------------
# Layout

HOME = Path.home()
HUB = Path(os.environ.get("KANBAN_HUB", HOME / ".kanban-hub")).resolve()
HUB_BIN = HUB / "bin"
HUB_PROMPTS = HUB / "prompts"
HUB_TEMPLATES = HUB / "templates"
HUB_STATIC = HUB / "static"
HUB_PROJECTS = HUB / "projects"
HUB_LOGS = HUB / "logs"

# When installed, the CLI lives at ~/.local/bin/kanban and the support files
# (bin/, prompts/, etc.) live in ~/.kanban-hub/. The install script copies them.
INSTALL_ROOT = Path(__file__).resolve().parent

C_RESET = "\033[0m"
C_BOLD  = "\033[1m"
C_DIM   = "\033[2m"
C_GREEN = "\033[32m"
C_YELLOW= "\033[33m"
C_RED   = "\033[31m"
C_BLUE  = "\033[34m"
C_CYAN  = "\033[36m"

def color(s, c): return f"{c}{s}{C_RESET}" if sys.stdout.isatty() else s

# ---------------------------------------------------------------------------
# Helpers

def slugify(name: str) -> str:
    s = re.sub(r"[^\w\s-]", "", name).strip().lower()
    s = re.sub(r"[-\s]+", "-", s)
    return s or "project"

def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()

def die(msg: str, code: int = 1):
    print(color(f"error: {msg}", C_RED), file=sys.stderr)
    sys.exit(code)

def require(cmd: str):
    if shutil.which(cmd) is None:
        die(f"{cmd!r} not found in PATH")

def load_board(project_dir: Path) -> dict:
    return json.loads((project_dir / "kanban.json").read_text())

def project_dir(name: str) -> Path:
    p = HUB_PROJECTS / slugify(name)
    if not p.exists():
        die(f"no project named {name!r} (looked at {p})")
    return p

def list_project_dirs() -> list[Path]:
    if not HUB_PROJECTS.exists():
        return []
    return sorted(p for p in HUB_PROJECTS.iterdir()
                  if p.is_dir() and (p / "kanban.json").exists())

def copy_clipboard(text: str) -> str | None:
    """Best-effort copy to clipboard. Returns the tool used, or None."""
    for cmd in (["pbcopy"], ["xclip", "-selection", "clipboard"],
                ["wl-copy"], ["clip.exe"]):
        if shutil.which(cmd[0]):
            try:
                subprocess.run(cmd, input=text, text=True, check=True)
                return cmd[0]
            except Exception:
                pass
    return None

def _dep_ok(dep_id, claiming_agent, done_ids, all_cards) -> bool:
    """Mirror of claim.sh's dependency rule (kept in sync deliberately):
    a same-agent dep is satisfied when done; a cross-agent dep must be
    merged_to_main so the code is actually present in the claiming worktree."""
    if dep_id not in done_ids:
        return False
    dep = all_cards.get(dep_id)
    if dep is None:
        return False
    if dep.get("agent") == claiming_agent:
        return True
    return bool(dep.get("merged_to_main"))

def claimable_count(board: dict) -> int:
    """How many todo cards are claimable right now (all deps satisfied)."""
    done_ids = {c["id"] for c in board["columns"]["done"]}
    all_cards = {c["id"]: c for col in board["columns"].values() for c in col}
    n = 0
    for c in board["columns"]["todo"]:
        deps = c.get("depends_on") or []
        if all(_dep_ok(d, c.get("agent"), done_ids, all_cards) for d in deps):
            n += 1
    return n

def awaiting_merge(board: dict) -> dict:
    """{agent: count} of done cards not yet merged to main. These are what a
    human needs to `kanban merge` to unblock cross-agent dependents."""
    out: dict = {}
    for c in board["columns"]["done"]:
        if not c.get("merged_to_main"):
            a = c.get("agent", "?")
            out[a] = out.get(a, 0) + 1
    return out

# ---------------------------------------------------------------------------
# process control — per-agent stop + global kill switch
#
# A running tick is `runner.sh <agent>`, which (via cmd_tick) is launched in its
# OWN process group and writes its PID to .run-<agent>.pid. To stop work in
# flight we signal that process group — killing runner.sh, `timeout`, and the
# `claude` child together. Pausing an agent (.paused-<agent>) or engaging the
# global kill switch (HUB/.killswitch) stops anything from restarting.

def killswitch_path() -> Path:
    return HUB / ".killswitch"

def killswitch_on() -> bool:
    return killswitch_path().exists()

def agent_pid(pdir: Path, agent: str):
    """Return the live PID for (project, agent) if its runner is alive, else None."""
    pf = pdir / f".run-{agent}.pid"
    if not pf.exists():
        return None
    try:
        pid = int(pf.read_text().strip())
        os.kill(pid, 0)            # liveness probe; raises OSError if dead
        return pid
    except (ValueError, OSError):
        return None

def stop_agent_proc(pdir: Path, agent: str) -> bool:
    """TERM (then KILL) the running process group for (project, agent).
    Returns True if a live process was signalled."""
    pid = agent_pid(pdir, agent)
    pf = pdir / f".run-{agent}.pid"
    if pid is None:
        pf.unlink(missing_ok=True)
        return False
    try:
        pgid = os.getpgid(pid)
        # Group-kill only when the runner is its own group leader (how cmd_tick
        # launches it, with start_new_session). Otherwise signal just the pid so
        # we never take down an unrelated process group (e.g. a dev's shell).
        group = (pgid == pid)
        (os.killpg if group else os.kill)(pgid if group else pid, signal.SIGTERM)
        time.sleep(1.5)
        if agent_pid(pdir, agent) is not None:
            (os.killpg if group else os.kill)(pgid if group else pid, signal.SIGKILL)
    except OSError:
        pass
    pf.unlink(missing_ok=True)
    return True

def stop_agent(pdir: Path, agent: str) -> bool:
    """Kill any running process for the agent AND pause it so it won't restart."""
    killed = stop_agent_proc(pdir, agent)
    (pdir / f".paused-{agent}").touch()
    return killed

def resume_agent(pdir: Path, agent: str):
    (pdir / f".paused-{agent}").unlink(missing_ok=True)

def agent_paused(pdir: Path, agent: str) -> bool:
    return (pdir / f".paused-{agent}").exists()

def engage_killswitch() -> list:
    """Kill every running agent across all projects and set the global flag so
    no further ticks fire until disengaged."""
    killed = []
    for pdir in list_project_dirs():
        try:
            board = load_board(pdir)
        except Exception:
            continue
        for agent in board.get("agents", {}):
            if stop_agent_proc(pdir, agent):
                killed.append(f"{pdir.name}/{agent}")
    killswitch_path().touch()
    return killed

def disengage_killswitch():
    killswitch_path().unlink(missing_ok=True)

# ---------------------------------------------------------------------------
# init

def cmd_init(args):
    HUB.mkdir(parents=True, exist_ok=True)
    HUB_PROJECTS.mkdir(exist_ok=True)
    HUB_LOGS.mkdir(exist_ok=True)
    # Copy the bundled support files (bin/, prompts/, templates/, static/)
    # from wherever the install script put them, into HUB.
    src_root = Path(os.environ.get("KANBAN_SOURCE", INSTALL_ROOT))
    for sub in ("bin", "prompts", "templates", "static"):
        src = src_root / sub
        dst = HUB / sub
        if src.exists():
            if dst.exists(): shutil.rmtree(dst)
            shutil.copytree(src, dst)
            # make scripts executable
            if sub == "bin":
                for p in dst.iterdir():
                    p.chmod(0o755)
    # Write a config stub if missing
    cfg = HUB / "config.json"
    if not cfg.exists():
        cfg.write_text(json.dumps({
            "created_at": now_iso(),
            "default_tools": "Read,Write,Edit,Bash,Grep,Glob",
        }, indent=2))
    print(color(f"✓ hub ready at {HUB}", C_GREEN))
    print(f"  next: {color('kanban new <project-name>', C_BOLD)}")

# ---------------------------------------------------------------------------
# new — create a project, then run intake

def cmd_new(args):
    name = " ".join(args.name).strip()
    if not name: die("project name required")
    slug = slugify(name)
    pdir = HUB_PROJECTS / slug
    if pdir.exists():
        die(f"project {slug!r} already exists at {pdir}")

    # Scaffold from templates
    pdir.mkdir(parents=True)
    (pdir / "agents").mkdir()
    (pdir / "worktrees").mkdir()
    (pdir / "logs").mkdir()
    (pdir / "repo").mkdir()

    # Empty placeholder board — the intake will populate it
    placeholder = {
        "project_name": name,
        "slug": slug,
        "created_at": now_iso(),
        "updated_at": now_iso(),
        "status": "intake",
        "agents": {},
        "columns": {"todo": [], "in_progress": [], "blocked": [], "done": []},
        "proposed_tasks": [],
        "notes_for_human": [],
    }
    (pdir / "kanban.json").write_text(json.dumps(placeholder, indent=2))

    # Copy the per-project scripts so the project is self-sufficient
    for fn in ("runner.sh", "claim.sh", "update-card.sh", "notify.sh", "setup-agents.sh"):
        shutil.copy(HUB_BIN / fn, pdir / fn)
        (pdir / fn).chmod(0o755)
    shutil.copy(HUB_PROMPTS / "runtime-agent.md", pdir / "agent-prompt.md")

    # Build the intake message and drop it as INTAKE.md inside the project
    intake = (HUB_PROMPTS / "new-project-intake.md").read_text()
    intake = intake.replace("{{PROJECT_NAME}}", name).replace("{{SLUG}}", slug)
    (pdir / "INTAKE.md").write_text(intake)

    print(color(f"✓ scaffolded {slug} at {pdir}", C_GREEN))

    # The launch line the user pastes into claude
    paste = ("Read INTAKE.md in this directory and conduct the project intake "
             "interview with me. When intake is complete, delete INTAKE.md.")
    tool = copy_clipboard(paste)
    if tool:
        print(f"  ✓ launch prompt copied to clipboard (via {tool})")
    else:
        print(f"  → paste this into claude: {color(paste, C_DIM)}")

    print()
    print(color("launching claude in interactive mode...", C_CYAN))
    print(color("(when intake is done, run: kanban view)", C_DIM))
    print()
    os.chdir(pdir)
    os.execvp("claude", ["claude"])

# ---------------------------------------------------------------------------
# add-card / add-agent — incremental intake on an existing project

def _intake_in_project(pdir: Path, prompt_file: str, paste: str):
    """Launch claude in the project dir with a templated intake prompt."""
    prompt = (HUB_PROMPTS / prompt_file).read_text()
    prompt = prompt.replace("{{PROJECT_NAME}}", load_board(pdir)["project_name"])
    intake_file = pdir / f".intake-{int(time.time())}.md"
    intake_file.write_text(prompt)
    paste_real = paste.replace("{{INTAKE_FILE}}", intake_file.name)
    tool = copy_clipboard(paste_real)
    if tool:
        print(f"✓ launch prompt copied to clipboard (via {tool})")
    else:
        print(f"→ paste into claude: {color(paste_real, C_DIM)}")
    print()
    os.chdir(pdir)
    os.execvp("claude", ["claude"])

def cmd_add_card(args):
    pdir = project_dir(args.project)
    _intake_in_project(
        pdir, "new-card-intake.md",
        "Read {{INTAKE_FILE}} and conduct the new-card intake interview, "
        "then append the card to kanban.json atomically."
    )

def cmd_add_agent(args):
    pdir = project_dir(args.project)
    _intake_in_project(
        pdir, "new-agent-intake.md",
        "Read {{INTAKE_FILE}} and conduct the new-agent intake interview. "
        "Update kanban.json and create agents/<name>.md, then run ./setup-agents.sh."
    )

# ---------------------------------------------------------------------------
# list / status

def cmd_list(args):
    dirs = list_project_dirs()
    if not dirs:
        print(color("no projects yet — try: kanban new <name>", C_DIM))
        return
    for pdir in dirs:
        b = load_board(pdir)
        n = {k: len(b["columns"][k]) for k in ("todo", "in_progress", "blocked", "done")}
        agents = ", ".join(b.get("agents", {})) or color("(no agents yet)", C_DIM)
        paused = (pdir / ".paused").exists()
        flag = color("PAUSED", C_YELLOW) if paused else color("active", C_GREEN)
        print(f"{color(pdir.name, C_BOLD)}  [{flag}]")
        print(f"  agents: {agents}")
        print(f"  todo {n['todo']}  ·  in_progress {color(n['in_progress'], C_CYAN)}  ·  "
              f"blocked {color(n['blocked'], C_YELLOW)}  ·  done {color(n['done'], C_GREEN)}")
        aw = awaiting_merge(b)
        if aw:
            total = sum(aw.values())
            detail = ", ".join(f"{a} ({c})" for a, c in sorted(aw.items()))
            print(color(f"  ⚠ {total} done card(s) awaiting merge: {detail}", C_YELLOW))
            print(color(f"    merge to unblock dependents:  "
                        f"kanban merge {pdir.name} <agent>", C_DIM))
        print()

def cmd_status(args):
    cmd_list(args)

# ---------------------------------------------------------------------------
# run / tick — the cron-driven core

def cmd_run(args):
    pdir = project_dir(args.project)
    agent = args.agent
    rc = subprocess.call(["./runner.sh", agent], cwd=pdir)
    sys.exit(rc)

def cmd_merge(args):
    """Merge an agent's branch into main, then flag its done cards merged_to_main
    so cross-agent dependents become claimable. This is the human's review gate:
    inspect the agent's branch, then run this to publish the work to main."""
    import fcntl
    pdir = project_dir(args.project)
    agent = args.agent
    board = load_board(pdir)
    if agent not in board.get("agents", {}):
        die(f"agent {agent!r} not declared in {pdir.name}")
    branch = board["agents"][agent]["branch"]
    repo = pdir / "repo"
    if not (repo / ".git").exists():
        die("repo/ not initialized — run ./setup-agents.sh first")

    def git(*a, check=True):
        return subprocess.run(["git", "-C", str(repo), *a],
                              capture_output=True, text=True, check=check)

    # repo/ must be on main to merge into it.
    cur = git("rev-parse", "--abbrev-ref", "HEAD").stdout.strip()
    if cur != "main":
        git("checkout", "main")

    ahead = git("rev-list", "--count", f"main..{branch}", check=False).stdout.strip() or "0"
    if ahead == "0":
        print(color(f"nothing to merge — {branch} has no commits beyond main", C_YELLOW))
    else:
        r = git("merge", "--no-ff", branch, "-m", f"merge {branch} into main", check=False)
        if r.returncode != 0:
            git("merge", "--abort", check=False)
            die(f"merge conflict merging {branch} into main — NOT merged.\n"
                f"resolve by hand:\n    cd {repo} && git merge {branch}\n\n"
                f"{r.stdout}\n{r.stderr}")
        print(color(f"✓ merged {branch} into main ({ahead} commit(s))", C_GREEN))

    # Flag done cards as merged under the board lock.
    with open(pdir / ".board-lock", "w") as lk:
        fcntl.flock(lk, fcntl.LOCK_EX)
        board = load_board(pdir)                 # reload fresh inside the lock
        before = claimable_count(board)
        now = now_iso()
        marked = 0
        for c in board["columns"]["done"]:
            if c.get("agent") == agent and not c.get("merged_to_main"):
                c["merged_to_main"] = True
                c["merged_at"] = now
                marked += 1
        board["updated_at"] = now
        tmp = pdir / ".kanban.merge.tmp"
        tmp.write_text(json.dumps(board, indent=2))
        os.replace(tmp, pdir / "kanban.json")
        after = claimable_count(board)

    print(f"  flagged {marked} done card(s) as merged_to_main")
    unblocked = max(0, after - before)
    if unblocked:
        print(color(f"  → {unblocked} card(s) now claimable on the next tick", C_GREEN))
    elif marked:
        print(color("  (no newly-claimable cards yet — dependents may need other merges too)", C_DIM))

def cmd_tick(args):
    """Iterate every project, fire each agent that has work. Background-parallel."""
    HUB_LOGS.mkdir(exist_ok=True)
    if killswitch_on():
        print(f"{now_iso()} kill switch engaged — no ticks fired (release: kanban unkill)")
        return
    fired = []
    for pdir in list_project_dirs():
        if (pdir / ".paused").exists():
            continue
        try:
            board = load_board(pdir)
        except Exception as e:
            print(f"skip {pdir.name}: {e}", file=sys.stderr)
            continue
        for agent in board.get("agents", {}):
            if agent_paused(pdir, agent):
                continue
            # Per-(project, agent) lock is inside runner.sh, so concurrent fires are safe.
            log_dir = pdir / "logs" / agent
            log_dir.mkdir(parents=True, exist_ok=True)
            logf = open(log_dir / "tick.log", "a")
            # start_new_session: give each runner its own process group so the
            # dashboard's stop button / kill switch can signal the whole tree
            # (runner.sh + timeout + claude) at once.
            subprocess.Popen(["./runner.sh", agent], cwd=pdir,
                             stdout=logf, stderr=subprocess.STDOUT,
                             start_new_session=True)
            fired.append(f"{pdir.name}/{agent}")
    if fired:
        print(f"{now_iso()} fired: {', '.join(fired)}")

# ---------------------------------------------------------------------------
# pause / resume

def cmd_pause(args):
    pdir = project_dir(args.project)
    (pdir / ".paused").touch()
    print(color(f"✓ paused {pdir.name}", C_YELLOW))

def cmd_resume(args):
    pdir = project_dir(args.project)
    if getattr(args, "agent", None):
        resume_agent(pdir, args.agent)
        print(color(f"✓ resumed {pdir.name}/{args.agent}", C_GREEN))
    else:
        (pdir / ".paused").unlink(missing_ok=True)
        print(color(f"✓ resumed {pdir.name}", C_GREEN))

def cmd_stop(args):
    pdir = project_dir(args.project)
    killed = stop_agent(pdir, args.agent)
    state = "killed live run" if killed else "nothing was running"
    print(color(f"✓ stopped {pdir.name}/{args.agent} ({state}) — agent paused", C_YELLOW))
    print(color(f"  resume with: kanban resume {pdir.name} {args.agent}", C_DIM))

def cmd_kill(args):
    killed = engage_killswitch()
    print(color("✗ KILL SWITCH ENGAGED — all agents stopped, all ticks blocked", C_RED))
    if killed:
        print("  killed in flight: " + ", ".join(killed))
    print(color("  release with: kanban unkill", C_DIM))

def cmd_unkill(args):
    disengage_killswitch()
    print(color("✓ kill switch released — ticks will resume on the next cron run", C_GREEN))

# ---------------------------------------------------------------------------
# cron

def cmd_cron(args):
    bin_path = shutil.which("kanban") or str(INSTALL_ROOT / "kanban")
    line = f"*/10 * * * * {bin_path} tick >> {HUB_LOGS / 'tick.log'} 2>&1"
    print("Add this line to your crontab (run `crontab -e`):")
    print()
    print(color(f"  {line}", C_BOLD))
    print()
    print("That's it. One cron entry runs every project and every agent —")
    print("per-(project, agent) locks prevent overlap and let everything run in parallel.")

# ---------------------------------------------------------------------------
# view — the hub server + browser

class HubHandler(BaseHTTPRequestHandler):
    def log_message(self, *a): pass  # silence access log

    def do_GET(self):
        url = urllib.parse.urlparse(self.path)
        path = url.path

        # API: list all projects
        if path == "/api/projects":
            data = []
            for pdir in list_project_dirs():
                try:
                    b = load_board(pdir)
                    data.append({
                        "slug": pdir.name,
                        "project_name": b.get("project_name", pdir.name),
                        "updated_at": b.get("updated_at"),
                        "status": b.get("status", "active"),
                        "paused": (pdir / ".paused").exists(),
                        "agents": list(b.get("agents", {}).keys()),
                        "counts": {k: len(b["columns"][k]) for k in
                                   ("todo", "in_progress", "blocked", "done")},
                        "in_progress_titles": [c.get("title","") for c in
                                               b["columns"]["in_progress"]],
                        "awaiting_merge": awaiting_merge(b),
                        "claimable": claimable_count(b),
                        "paused_agents": [a for a in b.get("agents", {})
                                          if agent_paused(pdir, a)],
                        "running_agents": [a for a in b.get("agents", {})
                                           if agent_pid(pdir, a) is not None],
                        "killswitch": killswitch_on(),
                    })
                except Exception:
                    continue
            return self._json(data)

        # API: one project's board
        m = re.match(r"^/api/projects/([\w-]+)$", path)
        if m:
            slug = m.group(1)
            pdir = HUB_PROJECTS / slug
            if not (pdir / "kanban.json").exists():
                return self._404()
            return self._json(load_board(pdir))

        # Static pages
        if path in ("", "/", "/index.html"):
            return self._serve_static("hub.html")
        m = re.match(r"^/project/([\w-]+)/?$", path)
        if m:
            return self._serve_static("board.html",
                replace={"{{SLUG}}": m.group(1)})
        m = re.match(r"^/static/(.+)$", path)
        if m:
            return self._serve_static(m.group(1))

        self._404()

    def do_POST(self):
        url = urllib.parse.urlparse(self.path)
        path = url.path
        q = urllib.parse.parse_qs(url.query)
        def arg(name):
            return (q.get(name) or [None])[0]

        # Global kill switch
        if path == "/api/kill":
            killed = engage_killswitch()
            return self._json({"ok": True, "killswitch": True, "killed": killed})
        if path == "/api/unkill":
            disengage_killswitch()
            return self._json({"ok": True, "killswitch": False})

        # Per-agent stop / resume
        slug, agent = arg("project"), arg("agent")
        if path in ("/api/stop", "/api/resume"):
            if not slug or not agent:
                return self._json({"ok": False, "error": "project and agent required"})
            pdir = HUB_PROJECTS / slug
            if not (pdir / "kanban.json").exists():
                return self._404()
            if agent not in load_board(pdir).get("agents", {}):
                return self._json({"ok": False, "error": f"no agent '{agent}'"})
            if path == "/api/stop":
                killed = stop_agent(pdir, agent)
                return self._json({"ok": True, "stopped": agent, "killed_live": killed})
            resume_agent(pdir, agent)
            return self._json({"ok": True, "resumed": agent})

        self._404()

    def _json(self, data):
        body = json.dumps(data).encode()
        self.send_response(200)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(body)

    def _serve_static(self, name, replace=None):
        f = HUB_STATIC / name
        if not f.exists():
            return self._404()
        body = f.read_text()
        if replace:
            for k, v in replace.items(): body = body.replace(k, v)
        body_b = body.encode()
        ctype = "text/html" if name.endswith(".html") else (
                "text/css" if name.endswith(".css") else "text/plain")
        self.send_response(200)
        self.send_header("Content-Type", ctype + "; charset=utf-8")
        self.send_header("Content-Length", str(len(body_b)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(body_b)

    def _404(self):
        self.send_response(404); self.end_headers(); self.wfile.write(b"404")

def _find_free_port(start=8765):
    for p in range(start, start + 50):
        with socket.socket() as s:
            try:
                s.bind(("127.0.0.1", p))
                return p
            except OSError:
                continue
    return start

def cmd_view(args):
    if not HUB_STATIC.exists():
        die(f"hub not initialized — run `kanban init` first")
    port = _find_free_port(args.port or 8765)
    server = ThreadingHTTPServer(("127.0.0.1", port), HubHandler)
    url = f"http://127.0.0.1:{port}/"
    if args.project:
        url += f"project/{slugify(args.project)}/"
    print(color(f"hub running on {url}  (Ctrl-C to stop)", C_GREEN))
    try:
        webbrowser.open(url)
    except Exception:
        pass
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print()
        server.server_close()

